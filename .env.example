# ---- Copy this file to .env.local and fill it in ----

# Public base URL of the app (no trailing slash).
# Local dev: http://localhost:3000   Prod: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to sign session cookies and salt IP hashes.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=ghosttagauthsecret

# ---- Postgres (required) ----
# Self-hosted via docker-compose (default creds below), or any managed PG.
DATABASE_URL=postgres://ghosttag:ghosttag@localhost:5432/ghosttag
# Max pooled connections per app instance (raise behind PgBouncer).
DB_POOL_MAX=10
# Set to true for remote/managed Postgres that requires TLS.
DATABASE_SSL=false

# ---- Telegram (recommended — the free instant-push channel) ----
# 1. Talk to @BotFather, /newbot, copy the token below.
# 2. /setdomain -> set it to your NEXT_PUBLIC_APP_URL host (for the Login Widget).
TELEGRAM_BOT_TOKEN=
# Your bot's username WITHOUT the @ (e.g. GhostTagBot)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# ---- Google login (optional — pings go by email for these users) ----
# Google Cloud Console -> Credentials -> OAuth client (Web).
# Authorized redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email fallback (optional — needed to ping Google-only users) ----
# Resend free tier: https://resend.com  -> API Keys
RESEND_API_KEY=
# A verified sender, e.g. GhostTag <alerts@yourdomain.com>
EMAIL_FROM=
